# short-description: Create a generic root filesystem disk image
# long-description: Create a generic partitioned image that contains the root filesystem.
#
# This WIC layout intentionally avoids board-specific bootloader offsets,
# bootloader blobs, and SoC-specific storage names. BSP layers can provide
# their own WKS files when a platform needs a custom boot layout.

part / --source rootfs --ondisk sda --fstype=ext4 --label root --align 4096

bootloader --ptable msdos
